# VAXIS Unified API: Configuration Template
# 作成者: VAXIS Development Team

# --- Supabase Settings ---
# プロジェクトURLとサービスロールキーを設定してください。
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Stripe Settings ---
# Stripe ダッシュボードから取得したシークレットキーを設定してください。
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- VAXIS Core Settings ---
# API サーバーの実行環境、クレジット価格などを定義可能です。
DEBUG=True
API_PORT=8000
ALLOWED_ORIGINS=["*"]
